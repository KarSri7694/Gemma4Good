{
  "mcpServers": {
    "Science Teacher Tools": {
      "command": "python",
      "args": [
        "mcp_servers/teacher_tools.py"
      ],
      "env": {
        "TEACHER_TOOL_SUBJECT": "Science",
        "TEACHER_TOOL_GRADE_BAND": "6-8"
      }
    },
        "Tavily" : {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.tavily.com/mcp/?tavilyApiKey=${TAVILY_API_KEY}"
      ],
      "env":{}
    }

  }
}
