# llama-server sampling controls
PROVIDER=LOCAL
LLAMA_TEMPERATURE=1.0
LLAMA_TOP_P=0.95
LLAMA_TOP_K=64
LLAMA_BASE_URL=http://127.0.0.1:8080
LLAMA_MODEL_NAME=Gemma-4-E4B-Q4_K_M
# For hosted OpenRouter usage, set PROVIDER=OPENROUTER and define OPENROUTER_API_KEY in the environment.
#OTHER MODES- ONE_BY_ONE, ONE_SHOT, AUTO
QUIZ_QUESTION_GENERATION_MODE=ONE_SHOT
AUTO_GRADE_POLL_INTERVAL_SECONDS=15
MAX_AGENT_ITERATIONS=10
SHOW_REASONING=true
EMBEDDING_MODEL_SERVER=http://127.0.0.1:8081
EMBEDDING_MODEL_NAME=embedding-model
RAG_CHUNK_TARGET_TOKENS=750
RAG_CHUNK_OVERLAP_TOKENS=150
RAG_TOP_K=5
